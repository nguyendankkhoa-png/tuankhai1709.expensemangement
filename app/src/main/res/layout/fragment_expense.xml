<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".fragments.ExpenseFragment">

    <!-- Filter Bar (Existing) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/white">

        <Spinner
            android:id="@+id/spn_filter_category"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:spinnerMode="dropdown" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/ed_filter_date"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Filter by date"
            android:focusable="false"
            android:clickable="true"
            android:inputType="none"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btn_clear_filter"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_gravity="center"
            android:layout_marginStart="8dp"
            android:text="Clear"
            android:textSize="12sp"
            android:paddingHorizontal="8dp"
            android:background="@drawable/rounded_button"
            app:backgroundTint="@null"
            android:textColor="@color/black"/>
    </LinearLayout>

    <!-- FIX: Added a LinearLayout to hold both recurring expense buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="12dp">

        <Button
            android:id="@+id/btn_add_recurring_expense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add Recurring"
            android:textSize="13dp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"
            android:background="@drawable/rounded_button"
            app:backgroundTint="@null"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/btn_show_recurring"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Show Recurring"
            android:textSize="13dp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:background="@drawable/rounded_button"
            app:backgroundTint="@null"
            android:textColor="@color/black"/>

    </LinearLayout>

    <!-- RecyclerView (Existing) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_transactions"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"
        android:clipToPadding="false"
        android:scrollbars="vertical" />

</LinearLayout>
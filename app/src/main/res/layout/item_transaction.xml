<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Category (e.g., Food) -->

        <!-- Note (e.g., Lunch meeting) -->
        <TextView
            android:id="@+id/tv_expense_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Type (Expense/Income Tag) -->

        <!-- Date -->

        <!-- Amount -->

        <!-- More Options Button -->

        <TextView
            android:id="@+id/tv_expense_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_expense_category"
            android:layout_marginTop="12dp"
            android:text="Note" />

        <TextView
            android:id="@+id/tv_expense_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_expense_name"
            android:layout_marginTop="11dp"
            android:background="#4CAF50"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Type"
            android:textColor="@android:color/white"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_expense_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="40dp"
            android:text="Date" />

        <TextView
            android:id="@+id/tv_expense_amount"
            android:layout_width="98dp"
            android:layout_height="19dp"
            android:layout_alignParentTop="true"
            android:layout_marginTop="67dp"
            android:layout_marginEnd="8dp"
            android:layout_toStartOf="@+id/tv_expense_date"
            android:text="Amount"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_option_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="56dp"
            android:layout_marginEnd="10dp"
            android:adjustViewBounds="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More options"
            android:maxWidth="24dp"
            android:maxHeight="24dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_edit" />

    </RelativeLayout>

</androidx.cardview.widget.CardView>